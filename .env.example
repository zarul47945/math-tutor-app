EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Optional legacy fallback if you are still using the older anon key format:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Do not put LIVEKIT_API_SECRET in this Expo env file for production.
# Set LIVEKIT_URL, LIVEKIT_API_KEY, and LIVEKIT_API_SECRET as Supabase Edge Function secrets instead.
